# --- Recommended: NVIDIA (same stack as OpenClaw in syncscript) ---
# OpenAI-compatible API: https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# Primary = strongest default for research / strategy / filings (highest-quality instruct on NVIDIA catalog).
# Fast tier = smoke/connectivity-only turns (ping, hi, …) — see lawbot/model_routing.py.
# List models: GET https://integrate.api.nvidia.com/v1/models (Bearer NVIDIA_API_KEY).
CHAT_MODEL=meta/llama-3.1-405b-instruct
CHAT_MODEL_FAST=meta/llama-3.3-70b-instruct
# Optional: strongest catalog id for high-stakes NVIDIA-only turns (document mode, audit, verify/strengthen, long messages).
# Empty = use CHAT_MODEL only. Does not apply to polish second pass (see lawbot/model_routing.py).
# CHAT_MODEL_MAX=
# Reasoning scaffold, session compaction, draft_judge: primary = CHAT_MODEL (max IQ); fast = CHAT_MODEL_FAST.
# Transient 429/5xx backoff for OpenAI-compatible chat (main + reasoning + compaction + draft judge)
LAWBOT_LLM_HTTP_RETRIES=4

LAWBOT_AUXILIARY_MODEL_TIER=primary

# Optional: other OpenAI-compatible hosts (if set, used when NVIDIA_API_KEY is empty)
# OPENAI_COMPATIBLE_API_KEY=

# Optional: Anthropic (paid). With NVIDIA also set: escalation for high-stakes turns (see LAWBOT_PARITY_ROADMAP.md §7).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Model used when escalating to Anthropic while NVIDIA is primary (empty = same as ANTHROPIC_MODEL).
ANTHROPIC_ESCALATION_MODEL=
# auto | never | always — when both NVIDIA and Anthropic keys exist.
LAWBOT_ANTHROPIC_ESCALATION=auto
# Max Anthropic escalations per UTC day when both backends configured (-1 = unlimited; 0 = never escalate).
LAWBOT_MAX_ANTHROPIC_ESCALATIONS_PER_DAY=-1

# --- Phases 3–8 (see docs/OPERATIONS.md, docs/LAWBOT_PARITY_ROADMAP.md) ---
# Internal reasoning scaffold (fast OpenAI-compatible call) before main reply: auto | never
LAWBOT_REASONING_PASS=auto
# Long-session memory: auto | never
LAWBOT_SESSION_COMPACTION=auto
LAWBOT_COMPACTION_MESSAGE_THRESHOLD=48
LAWBOT_COMPACTION_EVERY_N_MESSAGES=24
# Anthropic extended thinking on high-stakes turns: auto | never
LAWBOT_ANTHROPIC_THINKING=auto
LAWBOT_ANTHROPIC_THINKING_BUDGET_TOKENS=8000
# Chat endpoints only; 0 = off
LAWBOT_RATE_LIMIT_PER_MINUTE=0

# Session RAG (same OPENAI_BASE_URL as chat). NVIDIA nv-embedqa: Lawbot sends input_type=query|passage automatically.
LAWBOT_SESSION_RAG=auto
LAWBOT_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
LAWBOT_SESSION_RAG_TOP_K=4
LAWBOT_SESSION_RAG_MAX_STORED_CHUNKS=400
# Truncate session-RAG queries before embedding (avoids provider token limits); optional in-process cache
LAWBOT_SESSION_RAG_EMBED_MAX_CHARS=1800
LAWBOT_SESSION_RAG_EMBED_CACHE_TTL=300
LAWBOT_SESSION_RAG_EMBED_CACHE_MAX=256
# CourtListener retrieval cache (duplicate searches within TTL reuse vault chunks)
LAWBOT_CL_SEARCH_CACHE=true
LAWBOT_CL_SEARCH_CACHE_TTL_SECONDS=3600

# CourtListener API — https://www.courtlistener.com/help/api/ — never commit real tokens
COURTLISTENER_TOKEN=
# Forward citation counts via CourtListener opinions-cited API (not Westlaw KeyCite). auto | never
LAWBOT_CITATION_GRAPH=auto

# SQLite paths (defaults ok)
LAWBOT_DB_PATH=./data/lawbot.db

# Twilio SMS webhook — https://www.twilio.com/docs/sms
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VALIDATE_SIGNATURE=1

# HUD WebSocket pairing (set a long random string)
HUD_TOKEN=

# Public base URL for Twilio (must match webhook URL when validating)
PUBLIC_BASE_URL=https://your-tunnel.example.com
